# ── Required ──────────────────────────────────────────
OPENAI_API_KEY=
# ── Optional: Live Music APIs ─────────────────────────
# Ticketmaster Discovery API  →  https://developer.ticketmaster.com
TICKETMASTER_API_KEY=

# Spotify API  →  https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Setlist.fm API  →  https://api.setlist.fm/docs
SETLISTFM_API_KEY=

# ── Agent Behaviour ───────────────────────────────────
# Max failure-first loop iterations before producing final plan
MAX_LOOP_ITERATIONS=3

# Logging: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
